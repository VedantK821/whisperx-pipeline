# Hugging Face token — required for speaker diarization.
# Get one at https://huggingface.co/settings/tokens (read access is enough).
# You must also accept the user agreements on these gated models:
#   https://huggingface.co/pyannote/speaker-diarization-3.1
#   https://huggingface.co/pyannote/segmentation-3.0
HF_TOKEN=

# Model size: tiny | base | small | medium | large-v2 | large-v3
WHISPER_MODEL=large-v3

# Compute device: cuda | cpu  (auto-detect if blank)
DEVICE=

# Compute type: float16 (GPU) | int8 (CPU/low VRAM) | float32
COMPUTE_TYPE=float16

# Language code (e.g. en) or leave blank to auto-detect
LANGUAGE=

# Diarization speaker count hints (blank = auto)
MIN_SPEAKERS=
MAX_SPEAKERS=

# Pyannote diarization model. Leave blank to use whisperx's default
# (currently pyannote/speaker-diarization-community-1 — a separately gated repo).
# Set to pyannote/speaker-diarization-3.1 to use the older, more widely accepted model.
DIARIZE_MODEL=pyannote/speaker-diarization-3.1

# Folders (relative to project root)
INCOMING_DIR=incoming
TRANSCRIPTS_DIR=transcripts
MODELS_DIR=models
